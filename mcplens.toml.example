[proxy]
# Embedding provider: "local" (default, no API key needed) or "openai"
embedding_provider = "local"
# Model name (default: "all-MiniLM-L6-v2" for local, "text-embedding-3-small" for openai)
embedding_model = "all-MiniLM-L6-v2"
mfu_boost_weight = 0.15
mfu_persist = true
default_max_results = 5

[[servers]]
name = "example"
command = "uvx"
args = ["mcp-example-server"]
# env = { API_TOKEN = "${API_TOKEN}" }
